{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-sonnet-4-6",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(pnpm *)",
      "Bash(git diff *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(drizzle-kit generate)",
      "Bash(drizzle-kit migrate)",
      "Read(./app/**)",
      "Read(./components/**)",
      "Read(./lib/**)",
      "Read(./drizzle/**)",
      "Read(./tests/**)",
      "Edit(./app/**)",
      "Edit(./components/**)",
      "Edit(./lib/**)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git commit *)",
      "Bash(pnpm publish)",
      "Edit(./drizzle/migrations/**)",
      "Edit(./package.json)",
      "WebFetch"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(curl *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./node_modules/**)",
      "Edit(./.env*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "tool == 'Edit' && toolInput.file_path.endsWith('.sql')",
        "command": "echo 'WARN: editing raw SQL — prefer drizzle schema edits'",
        "type": "command"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "tool == 'Edit' && toolInput.file_path.startsWith('./components/')",
        "command": "pnpm biome check --apply {{toolInput.file_path}}",
        "type": "command"
      },
      {
        "matcher": "tool == 'Bash' && toolInput.command.includes('drizzle-kit migrate')",
        "command": "pnpm test:integration --filter=@acme/db",
        "type": "command"
      }
    ],
    "Stop": [
      {
        "matcher": "exitCode != 0",
        "command": "~/.claude/notify-failure.sh",
        "type": "command"
      }
    ]
  },
  "env": {
    "NODE_ENV": "development",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "DATABASE_URL_TEST": "postgres://test:test@localhost:5433/webshop_test"
  },
  "mcpServers": {
    "stripe": {
      "command": "npx",
      "args": ["-y", "@stripe/mcp-server"],
      "env": {
        "STRIPE_API_KEY": "${STRIPE_TEST_KEY}"
      }
    },
    "postgres": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres", "postgres://localhost:5432/webshop_dev"]
    }
  }
}
